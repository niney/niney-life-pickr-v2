NODE_ENV=development
PORT=3000
HOST=0.0.0.0

DATABASE_URL="file:../data/dev.db"

JWT_SECRET=change-me-to-a-secure-random-string-min-32-chars
JWT_EXPIRES_IN=7d

CORS_ORIGIN=http://localhost:5173,http://localhost:8081
LOG_LEVEL=debug

# Ollama Cloud — DB가 있으면 DB가 우선, 비어있으면 아래 값으로 fallback
OLLAMA_CLOUD_API_KEY=
OLLAMA_CLOUD_BASE_URL=https://ollama.com
OLLAMA_CLOUD_TIMEOUT_MS=60000
OLLAMA_CLOUD_MAX_CONCURRENT=15
# DB의 provider.defaultModel이 비어있을 때만 사용. 비워두면 매번 model 명시 필요.
OLLAMA_DEFAULT_MODEL=
