# =============================================================
# 서버
# =============================================================
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# =============================================================
# 데이터베이스 (SQLite + Prisma) — schema.prisma 기준 상대경로
# =============================================================
DATABASE_URL="file:../data/dev.db"

# =============================================================
# 인증 (JWT) — JWT_SECRET 은 32자 이상 무작위 문자열로 교체
# =============================================================
JWT_SECRET=change-me-to-a-secure-random-string-min-32-chars
JWT_EXPIRES_IN=7d

# =============================================================
# CORS / 로깅
# =============================================================
CORS_ORIGIN=http://localhost:5173,http://localhost:8081
LOG_LEVEL=debug

# #############################################################
# 어드민 > 설정 화면에서 DB로 덮어쓸 수 있는 값들.
#
# 공통 규칙: 아래 .env 값이 "기본". 설정 화면에서 저장하면 DB 값이 우선이 되고,
# "DB 설정 삭제"를 누르면 다시 이 .env 값으로 fallback 한다. 둘 다 비어 있으면
# 미설정(none) 상태. (설정 > 로그의 보존기간은 DB 전용 운영 노브라 env 없음.)
# #############################################################

# [설정 > AI 키] Ollama Cloud — DB의 LlmProviderConfig(purpose=chat) 행이 있으면
# 그 값이 우선. image/log-analysis 용도는 키가 없으면 이 계정 키를 상속한다.
OLLAMA_CLOUD_API_KEY=
OLLAMA_CLOUD_BASE_URL=https://ollama.com
OLLAMA_CLOUD_TIMEOUT_MS=60000
OLLAMA_CLOUD_MAX_CONCURRENT=15
# 용도별 기본 모델 — DB(provider.defaultModel)가 비어 있을 때만 사용. 셋 다
# 설정 화면(설정 > AI 키 > 용도별 모델)에서 DB로 덮어쓸 수 있다.
#  - OLLAMA_DEFAULT_MODEL:      텍스트(chat). 비우면 chat 은 매번 model 명시 필요.
#  - OLLAMA_IMAGE_MODEL:        이미지(vision, 영수증 추출 등). 비우면 image skip.
#  - OLLAMA_LOG_ANALYSIS_MODEL: 로그 분석(실패 작업 원인 분석). 비우면 분석 skip.
OLLAMA_DEFAULT_MODEL=gpt-oss:120b
OLLAMA_IMAGE_MODEL=qwen3.5:397b-cloud
OLLAMA_LOG_ANALYSIS_MODEL=deepseek-v4-pro

# [review-search 임베딩] ⚠️ Ollama Cloud 엔 임베딩 모델이 없다(401). 그래서 임베딩만은
# 로컬/사이드카 Ollama 가 필요하다. review-search 의 enrich·검색·ask(질의 임베딩은 매 요청)
# 가 모두 이 엔드포인트를 쓰므로, 운영에도 도달 가능한 Ollama 가 있어야 한다.
# 준비: 호스트에서 `ollama serve` + `ollama pull bge-m3`, 그리고 아래를 그 주소로.
# 확인: pnpm --filter friendly probe:embed-health
#  - OLLAMA_EMBED_BASE_URL: 임베딩 Ollama 주소(기본 http://localhost:11434).
#  - OLLAMA_EMBED_MODEL:    임베딩 모델(기본 bge-m3, dim 1024).
OLLAMA_EMBED_BASE_URL=http://localhost:11434
OLLAMA_EMBED_MODEL=bge-m3

# [설정 > 지도] vworld JS SDK / WMTS 키. 맛집 지도(공개)·식당 상세 지도가 사용.
# WMTS 키는 어차피 브라우저에 노출되는 클라이언트 자원이라 .env 기본값을 둬도
# 보안 등급 차이가 없다.
# - VWORLD_API_KEY: vworld JavaScript API 키.
# - VWORLD_DOMAINS: 허용 도메인 메모(콤마 구분). 런타임 미사용 — 표시·기록용.
VWORLD_API_KEY=
VWORLD_DOMAINS=localhost:5173,ninelife.kr

# [설정 > 텔레그램] 봇 — "맛집 자동 발굴"(어드민 > AI 분석 관리)이 후보를 보내고
# 사용자가 인라인 버튼으로 고른 가게만 크롤한다. 둘 다 있어야 동작하며, 비어
# 있으면 봇 비활성 → 회차가 자동으로 건너뜀(skip). 설정 화면 저장은 서버 재시작
# 없이 즉시 반영된다.
# - TELEGRAM_BOT_TOKEN: @BotFather 로 발급한 토큰 (형식 "<숫자>:<영숫자>").
# - TELEGRAM_CHAT_ID: 후보를 받을 chat id. 개인은 @userinfobot 의 숫자 Id,
#   그룹은 음수 값. 봇에 먼저 /start(또는 그룹에 추가)해야 전송 가능.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# #############################################################
# env 전용 (어드민 설정 화면 없음 — 배포 시 .env 로만 설정)
# #############################################################

# 영수증 추출 디버그 — 1이면 매 추출마다 raw LLM 응답/프롬프트/결과를
# data/extraction-debug/ 에 덤프(측정용). pnpm eval:extraction 으로 집계.
# 기본 0(끔). 프로덕션에선 켜지 말 것.
EXTRACTION_DEBUG=0

# 네이버 플레이스 크롤(Playwright) 튜닝 — env.ts 가 아니라 어댑터가 process.env
# 로 직접 읽는다(검증 없음). 모두 선택 — 미설정 시 아래 코드 기본값 사용.
# CRAWL_DEBUG_CAPTURE=0              # 1이면 스크린샷/HTML 덤프(__debug__/)
# CRAWL_HEADLESS=1                   # 0이면 브라우저 띄워서 실행(디버깅)
# CRAWL_SLOWMO=250                   # headed 모드 slow-mo(ms). headless 면 무시
# CRAWL_HOLD_MS=5000                 # headed 모드 서브페이지 종료 전 대기(ms)
# CRAWL_VISITOR_MAX_PAGES=100        # 방문자 리뷰 "더보기" 페이지네이션 상한
# CRAWL_VISITOR_PAGE_DELAY_MS=5000   # 클릭 간 지연(ms, 레이트리밋 회피)
# CRAWL_VISITOR_PAGE_DELAY_JITTER_MS=3000  # 위 지연에 더하는 랜덤 지터(ms)

# Deep link (iOS Universal Links / Android App Links) 검증 파일을 /.well-known/
# 라우트가 동적 생성한다. 비어 있으면 그 라우트가 404 → 앱이 자동 검증 실패로
# 폴백(브라우저 오픈).
# - APP_TEAM_ID: Apple Developer Team ID (10자, 예: ABCDE12345). app.config.ts 의
#   ios.bundleIdentifier 와 합쳐 AASA appIDs 에 들어간다.
# - APP_BUNDLE_ID: iOS bundle id. 미설정 시 'com.niney.lifepickr' 폴백.
# - ANDROID_APP_PACKAGE: 안드로이드 package. 미설정 시 'com.niney.lifepickr' 폴백.
# - ANDROID_SHA256_FINGERPRINTS: 콤마 구분 SHA-256 지문 (대문자 16진수, 콜론
#   구분 64자). EAS 빌드는 `eas credentials` 로 확인.
APP_TEAM_ID=
APP_BUNDLE_ID=com.niney.lifepickr
ANDROID_APP_PACKAGE=com.niney.lifepickr
ANDROID_SHA256_FINGERPRINTS=

# 정산 공유 링크 SNS 미리보기(OG) / canonical URL.
# - WEB_INDEX_PATH: 빌드된 웹 index.html 경로. 미설정 시 apps/web/dist/index.html
#   을 빌드 산출물 기준 상대경로로 탐색. (설정하려면 주석 해제 후 절대경로)
# - PUBLIC_ORIGIN: 공개 URL/canonical 기준 origin. Cloudflare/SSL/nginx Host
#   변형에 흔들리지 않게 SEO 표면을 운영 도메인으로 고정.
# - OG_IMAGE_PATH: OG 기본 이미지. 같은 도메인 정적 파일 path 또는 절대 URL.
# WEB_INDEX_PATH=
PUBLIC_ORIGIN=https://ninelife.kr
OG_IMAGE_PATH=/og-default.png
