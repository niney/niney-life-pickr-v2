generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  role         Role     @default(USER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  picks       Pick[]
  settlements SettlementSession[]
  contacts    SettlementContact[]
  drafts      SettlementDraft[]

  @@map("users")
}

enum Role {
  USER
  ADMIN
}

// 정산하기 — 한 번의 정산 세션. 차수(SettlementRound) 1개 이상으로 구성되며
// 각 차수는 서로 다른 식당일 수 있다. session 본체에 남는 restaurantPlaceId/
// restaurantName 은 '1차 식당' 스냅샷 — 목록 검색·이력 호환을 위해 중복 보유
// 한다 (rounds[0] 와 항상 동기화).
//
// 로그인 사용자 본인만 보고 편집할 수 있다 (개인 전용). 영수증 토큰·source·
// totalAmount 같은 차수 단위 정보는 모두 SettlementRound 로 이동했다.
model SettlementSession {
  id                String   @id @default(cuid())
  userId            String
  // 1차 식당의 placeId 스냅샷. rounds[0].restaurantPlaceId 와 동기화.
  restaurantPlaceId String
  // 1차 식당 이름 스냅샷.
  restaurantName    String
  // 모든 차수 itemsSubtotal 의 합. 클라이언트가 매번 계산하지 않아도 되도록 저장.
  grandTotal        Int
  // 공유 링크 토큰 — null 이면 비공개. POST /settlements/:id/share 로 owner 가
  // 생성/만료갱신, DELETE 로 회수. 토큰 자체는 추측 불가능한 7바이트 base64url(10자).
  // 만료(shareExpiresAt)가 항상 걸려 노출 창이 닫히므로 짧아도 안전.
  // unique 인덱스로 GET /share/settlements/:token 조회 O(1).
  shareToken        String?  @unique
  // 공유 링크 만료 시각 — 지나면 GET 공개 조회가 410. owner 가 다시 share 하면
  // ttl 기준으로 갱신(연장)된다. null = 만료 없음(구버전 토큰 호환).
  shareExpiresAt    DateTime?
  // 공유 미리보기(OG) 이미지 선택: 'restaurant'(식당 사진) | 'table'(정산표).
  // null = 미설정 → 기본 'restaurant'(식당 사진, 없으면 정산표로 폴백). 공유 시
  // owner 가 다이얼로그 토글로 정한다. share-preview 가 og:image 로 반영.
  shareOgImage      String?
  // 'restaurant' 모드에서 owner 가 갤러리에서 직접 고른 식당 사진의 원본 URL
  // (네이버 호스트). null = 미선택 → 토큰 시드로 결정적 랜덤 1장. 자동 랜덤이
  // 관련 없는 사진을 고르는 걸 피하려고 owner 가 특정 1장으로 고정할 수 있다.
  // 후보 목록에서 사라진 URL 은 share 시 정리(null 로) 된다.
  shareOgImageUrl   String?
  // 본문(참여자/차수/항목)이 저장 후 마지막으로 수정된 시각. 한 번도 수정 안
  // 했으면 null. updatedAt 과 분리한 이유: updatedAt 은 shareToken 발급/회수
  // 에도 갱신되어 '수정됨' 배지 기준으로 부적합.
  editedAt          DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user         User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  rounds       SettlementRound[]
  participants SettlementParticipant[]

  @@index([userId, createdAt])
  @@index([restaurantPlaceId])
  @@map("settlement_sessions")
}

// 한 정산 안의 한 차수. 같은 식당의 영수증 여러 장이든 다른 식당으로 이동한
// 2차이든 동일하게 round 1행. 식당 정보·영수증·source·totalAmount 가 모두
// round 단위.
model SettlementRound {
  id                String   @id @default(cuid())
  sessionId         String
  orderIndex        Int
  // 차수마다 다른 식당일 수 있으므로 round 단위 식당 snapshot.
  restaurantPlaceId String
  restaurantName    String
  // 'MANUAL' | 'RECEIPT' — 차수마다 다를 수 있다 (1차 영수증, 2차 직접 입력 등).
  source            String
  totalAmount       Int?
  warning           String?
  // 영수증 이미지 토큰 — data/receipts/<token>.jpg. MANUAL 차수는 null.
  receiptImageToken String?
  // 이 차수 items.amount 합 - discountAmount. session.grandTotal 의 부품.
  itemsSubtotal     Int
  // 차수 할인 — 영수증 쿠폰/멤버십 등. null 이면 할인 없음. 양수면 한
  // 카테고리(discountCategory) 풀에서만 차감. 풀 음수 차단은 zod refine.
  discountAmount    Int?
  discountCategory  String?
  // 분담 다듬기 — 카테고리별 잔여 처리 규칙을 JSON 으로 직렬화. 모양:
  // { [Category]: { leftoverParticipantIds: string[], roundUnit: number|null } }.
  // 수령자 1명=몰아주기, 여러 명=잔여 균등 분배. null/미설정이면 default(첫
  // 참여자 흡수). 레거시 단일 leftoverParticipantId 도 읽기 시 호환 처리.
  categoryAdjustments String?
  // 세부 분배 그룹(소주/맥주 잔수 등)을 JSON 배열로 직렬화. 모양:
  // [{ label, category, itemIndexes, mode: 'EQUAL'|'GLASSES',
  //    members: [{ participantId, glasses }] }]. null/미설정이면 없음.
  groupSplits         String?

  session    SettlementSession             @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  items      SettlementItem[]
  attendees  SettlementRoundParticipant[]

  @@index([sessionId])
  @@map("settlement_rounds")
}

model SettlementItem {
  id              String  @id @default(cuid())
  roundId         String
  // 사용자가 화면에서 본 그대로의 메뉴명.
  name            String
  unitPrice       Int?
  // 직접 입력 모드에서 빠뜨릴 수 있어 nullable.
  quantity        Int?
  // 라인 합계. 분배 계산은 이 값으로 한다.
  amount          Int
  // 'ALCOHOL' | 'NON_ALCOHOL' | 'SIDE' | 'UNCATEGORIZED'.
  category        String
  // 레스토랑 등록 메뉴 이름과 매칭됐을 때 정규화된 표기.
  matchedMenuName String?
  orderIndex      Int

  round SettlementRound @relation(fields: [roundId], references: [id], onDelete: Cascade)

  @@index([roundId])
  @@map("settlement_items")
}

// 마스터 참여자 — session 직속. exclude* 는 'default' 의미, 차수 단위 override
// 는 SettlementRoundParticipant 에서. shareAmount 는 모든 차수 분담의 grand
// total (per person).
model SettlementParticipant {
  id                String  @id @default(cuid())
  sessionId         String
  // 이름·닉네임 둘 중 하나만 채워져도 valid — application layer 가 검증.
  name              String?
  nickname          String?
  // 마스터 default. 차수 단위 override 가 없을 때 사용된다.
  excludeAlcohol    Boolean @default(false)
  excludeNonAlcohol Boolean @default(false)
  excludeSide       Boolean @default(false)
  // 모든 차수의 분담 합 (grand total). items/excludes/attendees 가 바뀌면
  // 서버가 다시 계산해 update.
  shareAmount       Int
  orderIndex        Int
  // 같은 사용자의 단골(SettlementContact) 과 연결. 자동 적립 시 매번 채워지고,
  // 단골이 삭제되면 SetNull 로 끊고 정산 본체는 그대로 둔다(이력 보존).
  contactId         String?

  session     SettlementSession              @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  contact     SettlementContact?             @relation(fields: [contactId], references: [id], onDelete: SetNull)
  roundEntries SettlementRoundParticipant[]

  @@index([sessionId])
  @@index([contactId])
  @@map("settlement_participants")
}

// 차수 × 참여자 join. attended=false 면 분담 = 0. excludeXxxOverride 가
// non-null 이면 마스터 default 를 무시하고 이 차수에서만 다른 값으로 친다.
// (예: 마스터에선 '술 X' 인데 이 차수에선 마심 → excludeAlcoholOverride=false)
model SettlementRoundParticipant {
  id                        String  @id @default(cuid())
  roundId                   String
  participantId             String
  attended                  Boolean @default(true)
  excludeAlcoholOverride    Boolean?
  excludeNonAlcoholOverride Boolean?
  excludeSideOverride       Boolean?
  // 이 차수에서의 분담액. 비참석이면 0.
  shareAmount               Int

  round       SettlementRound       @relation(fields: [roundId], references: [id], onDelete: Cascade)
  participant SettlementParticipant @relation(fields: [participantId], references: [id], onDelete: Cascade)

  @@unique([roundId, participantId])
  @@index([roundId])
  @@index([participantId])
  @@map("settlement_round_participants")
}

// 사용자별 "단골 참여자" 메모. 새 정산을 만들 때마다 모든 participant 가
// (userId, normalizedKey) 기준 upsert 된다 — 같은 사람을 매번 다시 입력하지
// 않고 자동완성으로 고르게 한다. lastExclude* 는 가장 최근 정산에서의 선택을
// 다음 정산의 default 로 제안하는 데 사용.
//
// normalizedKey = lower(trim(name)) + "|" + lower(trim(nickname)). 같은 사용자
// 안에서 unique — 정확 일치 자동완성 매칭의 키. 사용자가 직접 같은 이름을
// 타이핑해도 이 키로 기존 row 와 매칭된다.
model SettlementContact {
  id                    String    @id @default(cuid())
  userId                String
  // 표시용 — 정산을 만들 때 사용자가 입력한 마지막 표기 그대로 보존.
  name                  String?
  nickname              String?
  // 매칭/유니크 키. application layer 에서 정규화 함수가 채움. 직접 SQL 로
  // 만들 일이 없도록 service 에 전담.
  normalizedKey         String
  // 가장 최근 정산에서의 카테고리별 exclude 값. 다음 정산의 default 제안.
  lastExcludeAlcohol    Boolean   @default(false)
  lastExcludeNonAlcohol Boolean   @default(false)
  lastExcludeSide       Boolean   @default(false)
  // 등장 횟수. 자동완성 정렬·UI 노출 우선순위 후보. 현재는 표시만.
  useCount              Int       @default(1)
  // 자동완성 정렬용 (가장 최근에 쓴 사람을 위로).
  lastUsedAt            DateTime  @default(now())
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user         User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  participants SettlementParticipant[]

  @@unique([userId, normalizedKey])
  @@index([userId, lastUsedAt])
  @@map("settlement_contacts")
}

// 정산 입력 화면의 서버 임시저장. 자동저장(debounce)으로 다기기 동기화 목적.
// 사용자가 완성된 정산을 저장(SettlementSession 생성)하면 매칭 draft 는
// 자동 삭제된다.
//
// placeIdKey: '1차 식당으로 진입' 슬롯과 '/me/settlements/new' 슬롯을
// 분리하기 위한 unique 키. 후자는 빈 문자열 '' 로 둔다 (SQLite 의 NULL
// unique 가 다중 NULL 을 허용하기 때문에 sentinel 사용).
//
// payload: settlementDraftStore 상태(JSON 직렬화) 그대로. 서버는 스키마
// 검증을 하지 않고 보관만 한다 — 클라이언트 버전 진화에 유연하게.
model SettlementDraft {
  id            String   @id @default(cuid())
  userId        String
  placeIdKey    String   @default("")
  payload       String
  // 1차 식당 이름 캐시 — 이력 페이지 "이어 입력" 행 라벨용. 매번 payload 를
  // 파싱하지 않고도 표시 가능.
  placeNameHint String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, placeIdKey])
  @@index([userId, updatedAt])
  @@map("settlement_drafts")
}

model Pick {
  id        String   @id @default(cuid())
  userId    String
  title     String
  options   String
  category  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  results PickResult[]

  @@index([userId])
  @@map("picks")
}

model PickResult {
  id       String   @id @default(cuid())
  pickId   String
  chosen   String
  pickedAt DateTime @default(now())

  pick Pick @relation(fields: [pickId], references: [id], onDelete: Cascade)

  @@index([pickId])
  @@map("pick_results")
}

// 외부 지도 서비스 키. 현재는 vworld JS API 키만 사용하지만, 카카오/네이버
// 지도가 추가될 가능성을 열어두기 위해 LlmProviderConfig 와 같은 형태로
// provider 컬럼에 식별자(예: 'vworld')를 둔다. apiKey 는 admin 화면이 평문
// 으로 다시 받아와야 하기 때문에 (vworld JS SDK는 init 시 키를 그대로 URL
// 에 붙여 호출) AI 키와 달리 reveal 엔드포인트를 따로 둔다.
model MapProviderConfig {
  id          String   @id @default(cuid())
  provider    String   @unique
  apiKey      String
  // vworld는 키 발급 시 도메인 화이트리스트가 필수. 운영/로컬이 다르면
  // 키를 따로 둬야 하므로 여기는 단순 메모용. 콤마 구분 자유 입력.
  domains     String?
  updatedAt   DateTime @updatedAt
  updatedById String?

  @@map("map_provider_configs")
}

// purpose 컬럼은 같은 provider 를 용도별로 따로 등록할 수 있게 한다 — 텍스트
// 추론(chat)과 비전(image)이 보통 다른 모델이라 한 row 로 묶기 어렵다.
// 마이그레이션 시점에 기존 행은 모두 purpose='chat' 으로 채워진다.
model LlmProviderConfig {
  id            String   @id @default(cuid())
  provider      String
  purpose       String   @default("chat")
  apiKey        String
  baseUrl       String?
  defaultModel  String?
  enabled       Boolean  @default(true)
  maxConcurrent Int      @default(15)
  updatedAt     DateTime @updatedAt
  updatedById   String?

  @@unique([provider, purpose])
  @@map("llm_provider_configs")
}

// 출처 가로지르는 "같은 가게" 의 정체. Restaurant(N) → CanonicalRestaurant(1).
// 어드민이 Naver+다이닝코드 두 행을 같은 가게로 인식하면 두 Restaurant 가
// 같은 canonicalId 를 공유한다. 마이그레이션 직후엔 1:1 (각 Restaurant 가 자기
// 전용 Canonical 보유) 상태로 시작하고, merge API 호출로 점차 통합된다.
model CanonicalRestaurant {
  id              String   @id @default(cuid())
  // 표시용 가게명. merge 시 primary(보통 Naver) 행 이름 채택.
  name            String
  // 대표 카테고리 (primary 행).
  primaryCategory String?
  // 후보 매칭용 위경도 — 보통 primary 행과 동일. merge 시 primary 좌표 유지.
  latitude        Float?
  longitude       Float?
  // 빠른 후보 검색용 정규화 키 (normalizeName + 좌표 round). matching 유틸
  // 에서 채운다. 인덱스로 prefix scan.
  searchKey       String?
  // 어드민이 "이 가게는 다른 출처와 합칠게 없어" 라고 닫은 시각. 한 번 닫으면
  // list 응답의 suggestion 이 더 이상 노출되지 않는다. null 이면 노출 후보.
  // 새 등록 시점에 자동 산출되는 1차 제안에 한정 — 사용자가 직접 "병합" 패널을
  // 열면 별도 후보 API 가 풀 후보를 다시 계산한다.
  suggestionDismissedAt DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  restaurants Restaurant[]
  proposalsA  CanonicalMergeProposal[] @relation("ProposalCanonicalA")
  proposalsB  CanonicalMergeProposal[] @relation("ProposalCanonicalB")

  @@index([searchKey])
  @@index([latitude, longitude])
  @@map("canonical_restaurants")
}

// 자동 매칭이 두 canonical 을 "같은 가게일 수 있다" 고 잡았을 때 큐에 적재되는
// 검토 대기 항목. 정책상 자동 머지는 하지 않고 모두 사람이 확인 — score 가
// 임계(0.45) 이상이면 무조건 여기로 들어온다.
//
// 중복 방지를 위해 양방향 쌍을 정규화: 항상 canonicalAId < canonicalBId
// (cuid 문자열 사전순) 으로 저장. unique 제약으로 동일 쌍이 한 번만 큐에 뜬다.
//
// status 흐름:
//   open       — 어드민 검토 대기. UI 노출 대상.
//   accepted   — 어드민이 수락 → CanonicalService.merge 실행 → A/B 한쪽 소멸.
//   rejected   — 어드민이 "같은 가게 아님" 거절. 같은 쌍이 다시 제안되지 않음.
//   superseded — 다른 머지로 둘 중 한 canonical 이 사라짐(=stale). UI 에서 숨김.
model CanonicalMergeProposal {
  id             String   @id @default(cuid())
  canonicalAId   String
  canonicalBId   String
  score          Float
  nameScore      Float
  // 둘 다 좌표 있을 때만 채워짐. null 이면 이름 단독 매칭.
  distanceM      Float?
  status         String   @default("open")
  createdAt      DateTime @default(now())
  resolvedAt     DateTime?

  canonicalA CanonicalRestaurant @relation("ProposalCanonicalA", fields: [canonicalAId], references: [id], onDelete: Cascade)
  canonicalB CanonicalRestaurant @relation("ProposalCanonicalB", fields: [canonicalBId], references: [id], onDelete: Cascade)

  @@unique([canonicalAId, canonicalBId])
  @@index([status])
  @@map("canonical_merge_proposals")
}

model Restaurant {
  id             String   @id @default(cuid())
  // 외부 소스 식별자. source='naver'면 placeId 와 같은 값이 sourceId 에도 들어가고,
  // diningcode/catchtable 은 placeId 가 null. 공개 /restaurants/:placeId 라우트 호환을
  // 깨지 않으려 placeId 는 nullable 컬럼으로 남겨두되 신규 소스에서는 채우지 않는다.
  source         String   @default("naver")
  sourceId       String
  placeId        String?  @unique
  // 같은 가게의 다른 출처 행과 묶는 키. 마이그레이션 직후엔 모든 행이 자기
  // 전용 Canonical 을 가지고 (1:1), merge API 로 점차 N:1 이 된다. NOT NULL.
  canonicalId    String
  name           String
  category       String?
  address        String?
  phone          String?
  rating         Float?
  reviewCount    Int?
  rawSourceUrl   String
  snapshotJson   String
  firstCrawledAt DateTime @default(now())
  lastCrawledAt  DateTime @updatedAt

  canonical      CanonicalRestaurant @relation(fields: [canonicalId], references: [id])
  visitorReviews VisitorReview[]
  menuCanonicals MenuCanonical[]
  reviewClusters ReviewCluster[]

  @@unique([source, sourceId])
  @@index([source])
  @@index([canonicalId])
  @@map("restaurants")
}

// 식당 내 메뉴 표기 변형을 canonical 그룹으로 매핑하는 테이블.
// nameNorm = MenuMention.nameNorm 과 동일한 정규화 (소문자+공백/특수문자 제거).
// 한 식당 안에서 (nameNorm) → (canonicalName) 으로 묶고, canonicalNorm 은
// 통계 GROUP BY 키. version 은 MENU_GROUPING_VERSION — 프롬프트/모델 변경
// 시 stale 매핑 식별용.
model MenuCanonical {
  id             String   @id @default(cuid())
  restaurantId   String
  nameNorm       String
  canonicalName  String
  canonicalNorm  String
  version        Int      @default(1)
  model          String?
  createdAt      DateTime @default(now())

  restaurant Restaurant                @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  globalLink GlobalMenuCanonicalLink?

  @@unique([restaurantId, nameNorm])
  @@index([restaurantId, canonicalNorm])
  @@map("menu_canonicals")
}

// 식당 가로지르는 전역 canonical — 모든 식당의 MenuCanonical 그룹들을 다시
// LLM 으로 묶어 만든 단일 진실. 글로벌 메뉴 통계의 GROUP BY 키.
// version 변경 시 이전 매핑 stale.
model GlobalMenuCanonical {
  id            String   @id @default(cuid())
  // 표시용 표기 — 전역 대표 이름 (예: "김치찌개").
  displayName   String
  // 그룹 키 (displayName 의 normalizeTerm). 통계 쿼리의 GROUP BY 키.
  globalKey     String   @unique
  // 계층 카테고리 path (예: "한식 > 찌개 > 김치찌개"). null = 분류 없음.
  // 마지막 segment 는 displayName 과 같거나 약간 더 일반적인 표기. 통계 쿼리는
  // 항상 globalKey 로 GROUP BY 하고 categoryPath 는 표시·prefix 필터용.
  categoryPath  String?
  version       Int      @default(1)
  model         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  links GlobalMenuCanonicalLink[]

  @@index([categoryPath])
  @@map("global_menu_canonicals")
}

// 식당별 MenuCanonical → 전역 GlobalMenuCanonical 다대일 링크.
// (restaurantId, localCanonicalNorm) 가 유니크 — 한 식당의 한 그룹은
// 정확히 한 전역 그룹에만 속한다.
model GlobalMenuCanonicalLink {
  id                  String  @id @default(cuid())
  // MenuCanonical row 의 id 와 1:1 — onDelete: Cascade 로 동기화.
  menuCanonicalId     String  @unique
  // 빠른 조회용 비정규화 (restaurantId + localCanonicalNorm). MenuCanonical
  // 을 매번 조인하지 않아도 글로벌 키로 곧장 통계 가능.
  restaurantId        String
  localCanonicalNorm  String
  globalCanonicalId   String

  menuCanonical MenuCanonical       @relation(fields: [menuCanonicalId], references: [id], onDelete: Cascade)
  global        GlobalMenuCanonical @relation(fields: [globalCanonicalId], references: [id], onDelete: Cascade)

  @@index([globalCanonicalId])
  @@index([restaurantId])
  @@map("global_menu_canonical_links")
}

// 머지 청크 LLM 결과 메모이즈 — 같은 청크(입력 표기 배열, 순서 그대로)를 다시
// 묻지 않는다. cacheKey = sha256(model | schemaHash | variants). schemaHash 가
// 프롬프트·버전·카테고리 화이트리스트·샘플링 파라미터를 묶으므로, 그중 하나라도
// 바뀌면 키가 달라져 옛 캐시는 자연 미스(무효화). 성공 응답만 저장 — 실패 청크는
// 남기지 않아 다음 머지가 재시도하게 한다. 전량 머지여도 변하지 않은 청크는
// 히트로 LLM 을 건너뛴다(정확도는 동일, 같은 답 재사용).
model GlobalMergeChunkCache {
  id           String   @id @default(cuid())
  cacheKey     String   @unique
  mappingsJson String
  model        String
  schemaHash   String
  createdAt    DateTime @default(now())

  @@index([schemaHash])
  @@map("global_merge_chunk_cache")
}

model VisitorReview {
  id            String   @id @default(cuid())
  restaurantId  String
  externalId    String?
  authorName    String?
  rating        Int?
  body          String
  visitedAt     String?
  imageUrlsJson String
  videosJson    String   @default("[]")
  contentHash   String
  fetchedAt     DateTime @default(now())

  restaurant Restaurant     @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  summary    ReviewSummary?

  @@unique([restaurantId, externalId])
  @@unique([restaurantId, contentHash])
  @@index([restaurantId])
  @@map("visitor_reviews")
}

model ReviewSummary {
  id                String    @id @default(cuid())
  reviewId          String    @unique
  status            String
  text              String?
  model             String?
  errorCode         String?
  errorMessage      String?
  // 구조화된 분석 — LLM이 JSON으로 한 번에 추출.
  // sentiment: positive | negative | neutral | mixed
  sentiment         String?
  // -1.0 ~ 1.0
  sentimentScore    Float?
  // 1~5
  satisfactionScore Int?
  // [{ name, sentiment }] 직렬화
  menusJson         String?
  // string[] 직렬화 (예: "주차 협소", "예약 필수")
  tipsJson          String?
  // string[] 직렬화 — 분위기/서비스/가격 등 자유 태그
  keywordsJson      String?
  // 프롬프트/모델 변경 시 재분석 트리거용
  analysisVersion   Int?
  // ── review-search(문맥검색/RAG) enrichment ─────────────────────────────
  // bge-m3 임베딩(float[1024]) JSON 직렬화 — 인앱 코사인용.
  embeddingJson     String?
  // 관점→극성 {맛:"neg", 주차:"pos", ...} 직렬화 (구조 필터/검색).
  aspectsJson       String?
  // Contextual Retrieval 한 줄 — 임베딩 입력에 prepend(짧은 리뷰 recall↑).
  contextLine       String?
  // 위 enrichment 의 버전(프롬프트/모델 변경 시 재생성 트리거).
  enrichVersion     Int?
  // ── review-clustering(비슷한 문맥 리뷰 군집화) 멤버십 ──────────────────────
  // 배치로 재계산 시 함께 갱신. null = 노이즈/미분류("기타"). 군집 행 삭제 시 SetNull.
  clusterId         String?
  startedAt         DateTime?
  finishedAt        DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  review        VisitorReview   @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  menuMentions  MenuMention[]
  tags          ReviewTag[]
  cluster       ReviewCluster?  @relation(fields: [clusterId], references: [id], onDelete: SetNull)

  @@index([clusterId])
  @@map("review_summaries")
}

// 한 식당 리뷰를 "비슷한 문맥"끼리 묶은 군집(토픽). 저장된 bge-m3 임베딩으로
// UMAP→HDBSCAN→c-TF-IDF(Python 배치) 후 LLM 한 줄 라벨을 붙여 영속한다.
// 식당 단위로 통째 재계산(delete+insert) — clusterVersion 으로 재계산 게이트.
// 멤버십은 ReviewSummary.clusterId. 노이즈 리뷰는 어느 군집에도 속하지 않음(null).
model ReviewCluster {
  id               String   @id @default(cuid())
  restaurantId     String
  ordinal          Int      // 표시 순서 — size 내림차순.
  label            String   // LLM 한 줄 라벨 (예: "웨이팅이 긴 편")
  tone             String   // positive | negative | mixed | neutral
  size             Int      // 멤버 리뷰 수 = 카운트
  keywordsJson     String   // c-TF-IDF 상위 키워드 string[] 직렬화
  repReviewIdsJson String   // 대표 리뷰 id[] 직렬화 (읽기 시 body join)
  aspectsJson      String   // 집계 관점→극성 카운트 직렬화 (부가 라벨)
  clusterVersion   Int      // = CLUSTERING_VERSION (알고리즘/프롬프트 변경 시 ↑)
  createdAt        DateTime @default(now())

  restaurant Restaurant      @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  members    ReviewSummary[]

  @@index([restaurantId])
  @@map("review_clusters")
}

// 분석 done 시 menusJson 을 행 단위로 풀어 쓴 테이블. 글로벌·필터·검색
// 통계용. summaryId 단위로 한 번에 다시 써(delete + insert) 재분석/백필
// 결과와 자연스럽게 동기화된다.
model MenuMention {
  id           String   @id @default(cuid())
  summaryId    String
  restaurantId String
  // 원문 표기. UI 노출 시 사용.
  name         String
  // 그룹키 — 소문자 + 공백 제거. 동의어 사전은 추후 도입.
  nameNorm     String
  // positive | negative | neutral. v3 잔존 행에서 null 들어온 경우 'neutral'
  // 로 정규화해 저장한다(통계 쿼리에서 분기 줄임).
  sentiment    String
  // 메뉴 traits 원본 (string[] 직렬화). 빈도 집계가 필요해지면 별도 테이블로
  // 분리하지만, 지금은 응답 라운드트립용으로만 보존.
  traitsJson   String   @default("[]")

  summary      ReviewSummary @relation(fields: [summaryId], references: [id], onDelete: Cascade)

  @@index([nameNorm])
  @@index([restaurantId, nameNorm])
  @@index([summaryId])
  @@map("menu_mentions")
}

// 크롤+요약 잡의 단계별 로그. 어드민 UI 가 진행 상황·끊김 지점을 사후에도
// 추적할 수 있게 영속화. SSE 의 실시간 이벤트와 동일한 데이터를 DB 에도
// 저장해, 잡 종료 후 패널 재진입 시에도 같은 로그를 볼 수 있다.
//
// stage 는 CrawlStage 가 아니라 자유 문자열. 요약 파이프라인의 단계
// ('summary_queue', 'summary_attempt' 등) 까지 같은 테이블에 누적한다.
// meta 는 모델·지연ms·토큰·attempt 등 디버깅용 부가 정보의 JSON 직렬화.
model CrawlJobLog {
  id        String   @id @default(cuid())
  jobId     String
  placeId   String?
  stage     String
  level     String
  message   String
  meta      String?
  createdAt DateTime @default(now())

  @@index([jobId, createdAt])
  @@index([placeId, createdAt])
  @@map("crawl_job_logs")
}

// 범용 작업 실행(run) 헤더 — 크롤/요약/정규화/정산 추출 등 모든 기능의 실행
// 1회를 한 행으로 남긴다. CrawlJobLog 가 크롤+요약 전용이었던 것을 일반화한
// 후속 테이블. jobId/subjectId 는 기능별 의미가 달라(크롤 jobId, placeId,
// 'dc:<vRid>' 등) 자유 문자열로 둔다. 레거시 백필 행은 id 가 'legacy-<jobId>'.
model OperationRun {
  id           String    @id @default(cuid())
  // 8종: 'crawl'|'summary'|'menu-grouping'|'settlement-extraction'|
  // 'auto-discover'|'schedule'|'global-merge'|'diningcode-bulk-save'
  feature      String
  // 인메모리 레지스트리 잡 ID (crawl jobId, ScheduleRun.id 등). 레지스트리가
  // 없는 동기 실행(정산 추출 등)은 null.
  jobId        String?
  // placeId / restaurantId / 'dc:<vRid>' 등 — 대상 식별자.
  subjectId    String?
  // 중첩 run 연계 (schedule→menu-grouping 등). 부모 run 의 id.
  parentRunId  String?
  // 'running'|'done'|'failed'|'cancelled'. 재시작 고아는 부팅 sweep 이
  // 'failed'(errorCode='server_restart') 로 마감한다.
  status       String    @default("running")
  // 'manual'|'cron'|'auto'|'user' 등 — 기능별 어휘 상이.
  trigger      String?
  errorCode    String?
  // 2000자 캡 — application layer 에서 절단.
  errorMessage String?
  // JSON 직렬화, 4096자 캡. cacheHit/skipped 등 실행 부가 정보.
  meta         String?
  startedAt    DateTime  @default(now())
  finishedAt   DateTime?

  logs   OperationLog[]
  report OperationReport?

  @@index([feature, startedAt])
  @@index([status, startedAt])
  @@index([jobId])
  @@index([startedAt])
  @@map("operation_runs")
}

// run 의 스텝 단위 로그. feature/jobId/subjectId 는 run 에도 있지만 비정규화
// 해 둔다 — 레거시 크롤 로그 조회(jobId/placeId 기준)가 조인 없이 이 테이블만
// 으로 동작해야 하기 때문.
model OperationLog {
  id        String   @id @default(cuid())
  runId     String
  // 비정규화 — run.feature 와 동일.
  feature   String
  // 비정규화 — 레거시 크롤 로그 조회 호환용 (CrawlJobLogEntry.jobId non-null).
  jobId     String?
  // 비정규화 — placeId 기준 레거시 조회 유지용.
  subjectId String?
  stage     String
  // 'debug'|'info'|'warn'|'error'. debug 는 DB+pino 전용 (SSE 미발송).
  level     String
  // 2000자 캡.
  message   String
  // JSON 직렬화, 4096자 캡.
  meta      String?
  createdAt DateTime @default(now())

  run OperationRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId, createdAt])
  @@index([feature, createdAt])
  @@index([subjectId, createdAt])
  // 레거시 잡 로그 조회(jobId 기준)가 풀스캔하지 않도록.
  @@index([jobId, createdAt])
  @@index([createdAt])
  @@map("operation_logs")
}

// 실패 run 1건당 LLM 분석 보고서 1개 (runId unique). done 보고서만 보존
// 정리에서 제외되는 영구 기록(run 헤더+보고서만 남고 스텝 로그는 소멸) —
// 본문 없는 미완(pending/running/failed) 보고서는 보존 기간이 지나면 run 과
// 함께 정리된다.
model OperationReport {
  id               String   @id @default(cuid())
  runId            String   @unique
  // 'pending'|'running'|'done'|'failed'. failed 는 수동 '다시 분석' 으로 복구.
  status           String   @default("pending")
  provider         String?
  model            String?
  // 1-2문장 요약.
  summary          String?
  rootCause        String?
  // markdown 본문.
  details          String?
  // string[] JSON 직렬화 — 서버가 파싱해 배열로 응답.
  suggestions      String?
  // 'low'|'medium'|'high' — LLM JSON schema enum 으로 강제.
  severity         String?
  errorCode        String?
  errorMessage     String?
  promptTokens     Int?
  completionTokens Int?
  durationMs       Int?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  run OperationRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
  @@map("operation_reports")
}

// 로그 보존 설정 — 전역 단일 행(key='global'). ScheduleConfig 처럼 키 컬럼
// unique 로 upsert 하는 소형 설정 테이블.
model LogConfig {
  id            String   @id @default(cuid())
  key           String   @unique @default("global")
  // 보존 기간(일). cutoff 이전 로그/보고서 없는 run 을 매일 정리.
  retentionDays Int      @default(30)
  updatedAt     DateTime @updatedAt

  @@map("log_configs")
}

// tip + keyword 를 한 테이블에 통합. kind 로 구분 — 둘 다 free-form 짧은
// 한국어 태그라 스키마가 같다. 별도 테이블로 쪼개면 조회 쿼리만 두 번 나서
// 캐시 키도 늘어난다.
model ReviewTag {
  id           String   @id @default(cuid())
  summaryId    String
  restaurantId String
  // 'tip' | 'keyword'
  kind         String
  term         String
  termNorm     String

  summary      ReviewSummary @relation(fields: [summaryId], references: [id], onDelete: Cascade)

  @@index([kind, termNorm])
  @@index([restaurantId, kind])
  @@index([summaryId])
  @@map("review_tags")
}

// 주기 자동 실행 설정 — 관리자가 cron 으로 "정규화 → 글로벌 머지" 파이프라인을
// 예약. jobType 당 한 행(현재는 'normalize-merge' 단일). 부팅 시 이 행을 읽어
// 인프로세스 스케줄러(croner)에 등록하고, 어드민이 바꾸면 런타임 재등록한다.
// 단일 인스턴스라 분산 락은 불필요 — CLAUDE.md 의 no-Redis 전제와 일관.
model ScheduleConfig {
  id         String    @id @default(cuid())
  // 작업 종류 — 행 식별 키. 현재는 'normalize-merge' 하나.
  jobType    String    @unique
  enabled    Boolean   @default(false)
  // cron 식 (5필드). 예: '0 3 * * *' = 매일 03:00. 검증은 croner 가 한다.
  cronExpr   String
  // IANA 타임존. 기본 Asia/Seoul.
  timezone   String    @default("Asia/Seoul")
  // 마지막 실행 시각/결과 — 빠른 표시용 비정규화. 상세 이력은 ScheduleRun.
  // nextRunAt 은 저장하지 않는다 — croner 로 매번 계산(저장하면 stale).
  lastRunAt  DateTime?
  lastStatus String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@map("schedule_configs")
}

// 주기 작업 한 번의 실행 기록 — 이력 조회/감사용. status='running' 으로 시작해
// done/failed/interrupted 로 마감한다. skipped 는 이전 실행이 아직 안 끝나
// 이번 tick 을 건너뛴(overlap 방지) 경우를 한 행으로 남긴다.
model ScheduleRun {
  id             String    @id @default(cuid())
  jobType        String
  // 'cron' | 'manual'
  trigger        String
  // 'running' | 'done' | 'failed' | 'skipped' | 'interrupted'
  status         String
  // collecting 단계 후 확정된 처리 대상 식당 수. 미정 시 null.
  totalTargets   Int?
  // 정규화(grouping) 완료 식당 수.
  processedCount Int       @default(0)
  // 크롤 진행 중이라 이번 실행에서 제외한 식당 수.
  skippedCount   Int       @default(0)
  error          String?
  startedAt      DateTime  @default(now())
  finishedAt     DateTime?

  @@index([jobType, startedAt])
  @@map("schedule_runs")
}

// 맛집 자동 발굴 설정 — cron 으로 지역을 (랜덤/고정) 골라 검색 → 후보를
// 텔레그램으로 보내고 사용자가 고른 가게만 크롤. schedule_configs 와 같은
// 형태지만 지역/검색 설정이 추가된다. 텔레그램 토큰은 env 에 두고 여기 저장
// 안 한다(설정 화면에 노출 금지).
model RandomCrawlConfig {
  id                 String    @id @default(cuid())
  // 'random-crawl' 고정. 행 식별 키.
  jobType            String    @unique
  enabled            Boolean   @default(false)
  cronExpr           String    @default("0 11 * * *")
  timezone           String    @default("Asia/Seoul")
  // RandomCrawlRegion 직렬화 JSON (시/구/동 + 랜덤 플래그).
  regionJson         String    @default("{}")
  // 검색 키워드 — 동 이름과 결합. 기본 "맛집".
  keyword            String    @default("맛집")
  // 텔레그램으로 보낼 후보 수.
  candidateCount     Int       @default(5)
  // 무응답 시 회차를 닫기까지 대기할 분. (앱 기본값은 30 — DEFAULT_TIMEOUT_MIN.
  // DB default 는 실사용 안 됨: updateConfig 가 항상 값을 지정하고 getConfig 는
  // 행 없을 때 앱 상수로 폴백. 컬럼 default 변경은 SQLite 테이블 재생성을 유발해
  // 일부러 180 유지.)
  responseTimeoutMin Int       @default(180)
  // 무응답 시 동작 — "skip"(건너뛰기) | "random"(랜덤 자동 크롤).
  timeoutAction      String    @default("skip")
  lastRunAt          DateTime?
  lastStatus         String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@map("random_crawl_configs")
}

// 자동 발굴 한 회차. running → awaiting_selection(텔레그램 응답 대기) →
// crawling → done. 무응답/후보0/overlap 은 skipped, 오류는 failed, 재시작
// 고아는 interrupted. 텔레그램 콜백이 chatId+messageId 로 이 행을 찾아 선택을
// 반영하므로 두 값을 영속한다(메모리만으로는 재시작에 약함).
model RandomCrawlRun {
  id                  String    @id @default(cuid())
  // 'cron' | 'manual'
  trigger             String
  // running|awaiting_selection|crawling|done|skipped|failed|interrupted
  status              String
  // 선정된 지역 표시용. 예: "서울특별시 강남구 역삼동".
  regionLabel         String?
  keyword             String?
  // RandomCrawlCandidate[] 직렬화 JSON.
  candidatesJson      String    @default("[]")
  selectedPlaceId     String?
  crawledRestaurantId String?
  // 텔레그램 응답 매칭용 — 후보를 보낸 메시지.
  telegramChatId      String?
  telegramMessageId   String?
  // awaiting_selection 만료 시각 — 지난 회차는 sweep 이 skipped 로 닫는다.
  expiresAt           DateTime?
  error               String?
  startedAt           DateTime  @default(now())
  finishedAt          DateTime?

  @@index([status])
  @@index([startedAt])
  @@map("random_crawl_runs")
}

// 텔레그램 봇 설정 — 단일 행(key 고정). LlmProviderConfig/MapProviderConfig 와
// 같은 "DB 우선 + .env fallback" 패턴. DB 행이 있으면 그 값을 쓰고, 없으면
// env(TELEGRAM_*)로 폴백한다. 어드민 "설정 > 텔레그램"에서 관리.
model TelegramConfig {
  id          String   @id @default(cuid())
  // 단일 행 보장용 고정 키.
  key         String   @unique @default("telegram")
  botToken    String   @default("")
  chatId      String   @default("")
  updatedAt   DateTime @updatedAt
  updatedById String?

  @@map("telegram_configs")
}
