generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  role         Role     @default(USER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  picks Pick[]

  @@map("users")
}

enum Role {
  USER
  ADMIN
}

model Pick {
  id        String   @id @default(cuid())
  userId    String
  title     String
  options   String
  category  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  results PickResult[]

  @@index([userId])
  @@map("picks")
}

model PickResult {
  id       String   @id @default(cuid())
  pickId   String
  chosen   String
  pickedAt DateTime @default(now())

  pick Pick @relation(fields: [pickId], references: [id], onDelete: Cascade)

  @@index([pickId])
  @@map("pick_results")
}

model LlmProviderConfig {
  id            String   @id @default(cuid())
  provider      String   @unique
  apiKey        String
  baseUrl       String?
  defaultModel  String?
  enabled       Boolean  @default(true)
  maxConcurrent Int      @default(15)
  updatedAt     DateTime @updatedAt
  updatedById   String?

  @@map("llm_provider_configs")
}

model Restaurant {
  id             String   @id @default(cuid())
  placeId        String   @unique
  name           String
  category       String?
  address        String?
  phone          String?
  rating         Float?
  reviewCount    Int?
  rawSourceUrl   String
  snapshotJson   String
  firstCrawledAt DateTime @default(now())
  lastCrawledAt  DateTime @updatedAt

  visitorReviews VisitorReview[]

  @@map("restaurants")
}

model VisitorReview {
  id            String   @id @default(cuid())
  restaurantId  String
  externalId    String?
  authorName    String?
  rating        Int?
  body          String
  visitedAt     String?
  imageUrlsJson String
  contentHash   String
  fetchedAt     DateTime @default(now())

  restaurant Restaurant     @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  summary    ReviewSummary?

  @@unique([restaurantId, externalId])
  @@unique([restaurantId, contentHash])
  @@index([restaurantId])
  @@map("visitor_reviews")
}

model ReviewSummary {
  id                String    @id @default(cuid())
  reviewId          String    @unique
  status            String
  text              String?
  model             String?
  errorCode         String?
  errorMessage      String?
  // 구조화된 분석 — LLM이 JSON으로 한 번에 추출.
  // sentiment: positive | negative | neutral | mixed
  sentiment         String?
  // -1.0 ~ 1.0
  sentimentScore    Float?
  // 1~5
  satisfactionScore Int?
  // [{ name, sentiment }] 직렬화
  menusJson         String?
  // string[] 직렬화 (예: "주차 협소", "예약 필수")
  tipsJson          String?
  // string[] 직렬화 — 분위기/서비스/가격 등 자유 태그
  keywordsJson      String?
  // 프롬프트/모델 변경 시 재분석 트리거용
  analysisVersion   Int?
  startedAt         DateTime?
  finishedAt        DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  review VisitorReview @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@map("review_summaries")
}
