{
  "name": "friendly",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/server.ts",
    "build": "tsup",
    "start": "node --env-file=.env dist/server.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:reset": "prisma migrate reset",
    "db:studio": "prisma studio",
    "promote-admin": "tsx --env-file=.env scripts/promote-admin.ts",
    "backfill:contacts": "tsx --env-file=.env scripts/backfill-contacts.ts",
    "eval:extraction": "tsx scripts/eval-extraction.ts",
    "probe:extraction": "tsx --env-file=.env scripts/probe-extraction.ts",
    "probe:merge": "tsx --env-file=.env scripts/probe-merge.ts",
    "probe:tabling": "tsx --env-file=.env scripts/probe-tabling.ts",
    "probe:tabling-bulk": "tsx --env-file=.env scripts/probe-tabling-bulk.ts",
    "probe:tabling-promote": "tsx --env-file=.env scripts/probe-tabling-promote.ts",
    "run-merge": "tsx --env-file=.env scripts/run-global-merge.ts",
    "snapshot:merge": "tsx --env-file=.env scripts/snapshot-global-merge.ts",
    "dev:capture-visitor": "tsx scripts/dev-capture-visitor.ts",
    "dev:fetch-visitor-html": "tsx scripts/dev-fetch-visitor-html.ts",
    "dev:open-visitor-page": "tsx scripts/dev-open-visitor-page.ts",
    "dev:capture-catchtable": "tsx scripts/dev-capture-catchtable.ts",
    "clean": "rimraf dist .turbo",
    "probe:vision": "tsx --env-file=.env scripts/probe-vision.ts",
    "probe:review-search": "tsx --env-file=.env research/review-search/probe-e2e.ts",
    "probe:eval": "tsx --env-file=.env research/review-search/probe-eval.ts",
    "probe:completeness": "tsx --env-file=.env research/review-search/probe-completeness.ts"
  },
  "dependencies": {
    "@fastify/autoload": "^6.0.3",
    "@fastify/cors": "^10.0.1",
    "@fastify/helmet": "^13.0.0",
    "@fastify/jwt": "^9.0.1",
    "@fastify/multipart": "^10.0.0",
    "@fastify/sensible": "^6.0.2",
    "@fastify/swagger": "^9.4.0",
    "@fastify/swagger-ui": "^5.2.0",
    "@prisma/client": "^6.0.1",
    "@repo/api-contract": "workspace:*",
    "@repo/utils": "workspace:*",
    "@resvg/resvg-js": "^2.6.2",
    "bcryptjs": "^2.4.3",
    "croner": "^10.0.1",
    "fastify": "^5.2.0",
    "fastify-plugin": "^5.0.1",
    "fastify-type-provider-zod": "^4.0.2",
    "heic-convert": "^2.1.0",
    "lru-cache": "^11.5.1",
    "pino-pretty": "^13.0.0",
    "playwright": "^1.59.1",
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "satori": "^0.26.0",
    "sharp": "^0.34.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@repo/config": "workspace:*",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.10.2",
    "eslint": "^10.4.1",
    "prisma": "^6.0.1",
    "rimraf": "^6.0.1",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
